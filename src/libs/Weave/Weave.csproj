<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <PropertyGroup Label="Nuget">
    <PackageId>tryAGI.Weave</PackageId>
    <Description>C# SDK for the W&amp;B Weave API -- LLM observability with traces, evaluations, and datasets.</Description>
    <PackageTags>csharp;dotnet;sdk;ai;autosdk;openapi;wandb;weave;observability;tracing</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.5.0" />
  </ItemGroup>

  <PropertyGroup>
    <NoWarn>$(NoWarn);CS3002;CS3003;CS1591</NoWarn>
  </PropertyGroup>

</Project>
